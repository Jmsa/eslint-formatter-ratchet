{
  "name": "eslint-formatter-ratchet",
  "version": "3.0.0",
  "main": "dist/index.js",
  "repository": "https://github.com/Jmsa/eslint-formatter-ratchet.git",
  "description": "Ratcheting applied to ESLint results so new issues don't creep in.",
  "author": "James Abercrombie <jmsabercrombie88@gmail.com>",
  "license": "MIT",
  "keywords": [
    "eslint",
    "eslint-formatter",
    "eslintformatter",
    "ratchet"
  ],
  "files": [
    "README.md",
    "LICENSE.txt",
    "MIGRATING.md",
    "dist/index.js"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "yarn build && FORCE_COLOR=false vitest run",
    "test:ci": "yarn build && FORCE_COLOR=false vitest run --coverage",
    "release": "yarn build && standard-version"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "yarn test",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "**/*.{js,ts,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@types/node": "22.13.0",
    "@vitest/coverage-v8": "2.1.9",
    "husky": "9.1.7",
    "lint-staged": "15.4.3",
    "prettier": "3.4.2",
    "standard-version": "9.5.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "dependencies": {
    "chalk": "4.1.2",
    "deep-object-diff": "1.1.9",
    "eslint-formatter-table": "7.32.1"
  }
}
